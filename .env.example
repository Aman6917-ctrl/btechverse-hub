# Copy to .env and fill with your values. NEVER commit .env to Git.

# ============ Frontend (VITE_*) – needed for build & runtime ============
# Supabase (if used)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Firebase Auth (required for login)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Admin emails (comma-separated) – only these see Upload in navbar
VITE_ADMIN_EMAILS=

# API base URL – production me apna backend URL (e.g. https://api.yoursite.com)
VITE_API_BASE_URL=http://localhost:3001

# WebRTC ICE — STUN + TURN (see docs/WEBRTC_TURN.md)
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
# all | relay (relay = TURN-only test mode)
VITE_ICE_TRANSPORT_POLICY=all
VITE_ICE_RESTART_MAX_ATTEMPTS=3
VITE_ICE_DISCONNECT_GRACE_MS=4500

# ============ Server only (never exposed in frontend) ============
# AI Buddy – OpenRouter https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# AWS S3 – scripts / presign only
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
S3_BUCKET=

# Book Session – Resend https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
BOOK_SESSION_ADMIN_EMAIL=

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
BOOK_SESSION_ADMIN_WHATSAPP=
